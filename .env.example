SUPABASE_URL=###
SUPABASE_KEY=###

# Required for integration tests only (npm run test:integration).
# ANON_KEY must be the JWT-format key (not the sb_publishable_... in .dev.vars).
# Obtain: supabase start && export $(supabase status -o env | grep -E 'ANON_KEY|SERVICE_ROLE_KEY')
# Never commit real keys.
# ANON_KEY=###
# SERVICE_ROLE_KEY=###
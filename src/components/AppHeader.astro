---
// Branded app header: cosmic wordmark + logo on the left, account menu on the
// right. Replaces the old utilitarian `Topbar`. Primary navigation now lives in
// `BottomNav`, so this header is purely brand + account. Server-rendered: the
// account menu is a pure-CSS <details> disclosure, no client JS.
const { user } = Astro.locals;

// First letter of the email, used as a compact avatar glyph.
const initial = user?.email?.[0]?.toUpperCase() ?? "?";
---

<header class="border-b border-white/10 bg-white/5 backdrop-blur-xl">
  <div class="mx-auto flex w-full max-w-md items-center justify-between px-4 py-3">
    <a
      href="/dashboard"
      aria-label="Money Tracker — go to dashboard"
      class="flex items-center gap-2 rounded-lg focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:outline-none"
    >
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true" class="shrink-0">
        <defs>
          <linearGradient id="mt-logo" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
            <stop stop-color="#bfdbfe"></stop>
            <stop offset="1" stop-color="#d8b4fe"></stop>
          </linearGradient>
        </defs>
        <circle cx="16" cy="16" r="14" stroke="url(#mt-logo)" stroke-width="2"></circle>
        <path
          d="M9 20l4.5-5 3.5 3 5.5-7"
          stroke="url(#mt-logo)"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      <span class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-base font-bold text-transparent">
        Money Tracker
      </span>
    </a>

    {
      user ? (
        <details class="group relative">
          <summary
            class="flex size-9 cursor-pointer list-none items-center justify-center rounded-full border border-white/20 bg-white/10 text-sm font-semibold text-white transition-colors hover:bg-white/20 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:outline-none [&::-webkit-details-marker]:hidden"
            aria-label="Account menu"
          >
            {initial}
          </summary>
          <div class="absolute right-0 z-50 mt-2 w-56 rounded-xl border border-white/10 bg-[#0f1529]/95 p-3 text-sm text-white shadow-xl backdrop-blur-xl">
            <p class="mb-2 truncate text-blue-100/70" title={user.email}>
              {user.email}
            </p>
            <form method="POST" action="/api/auth/signout">
              <button
                type="submit"
                class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-left text-white transition-colors hover:bg-white/20 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:outline-none"
              >
                Sign out
              </button>
            </form>
          </div>
        </details>
      ) : (
        <div class="flex gap-3 text-sm">
          <a
            href="/auth/signin"
            class="rounded-md text-purple-300 transition-colors hover:text-purple-100 hover:underline focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:outline-none"
          >
            Sign in
          </a>
          <a
            href="/auth/signup"
            class="rounded-md text-purple-300 transition-colors hover:text-purple-100 hover:underline focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:outline-none"
          >
            Sign up
          </a>
        </div>
      )
    }
  </div>
</header>

---
type Variant = "info" | "warning" | "error";

interface Props {
  variant?: Variant;
}

const { variant = "info" } = Astro.props;
---

<div
  class:list={[
    "border-b px-4 py-3 text-center text-sm [&_a]:font-semibold [&_a]:underline",
    variant === "info" && "border-blue-400/30 bg-blue-900/40 text-blue-100",
    variant === "warning" && "border-amber-400/30 bg-amber-900/40 text-amber-200",
    variant === "error" && "border-red-500/40 bg-red-900/40 text-red-200",
  ]}
  role={variant === "error" ? "alert" : "status"}
>
  <slot />
</div>

---
import AppShell from "@/components/AppShell.astro";
import PageTitle from "@/components/ui/PageTitle.astro";
import BackLink from "@/components/ui/BackLink.astro";
import EmptyState from "@/components/ui/EmptyState.astro";
import ExpenseForm from "@/components/expenses/ExpenseForm";
import { createClient } from "@/lib/supabase";
import { getCurrentBudgetYear } from "@/lib/budget-year";
import { todayInWarsaw } from "@/lib/expense-write";

const { user } = Astro.locals;
const { id } = Astro.params;
const error = Astro.url.searchParams.get("error");
const year = getCurrentBudgetYear();
const today = todayInWarsaw();

interface CategoryRow {
  id: string;
  name: string;
  is_system: boolean;
}

let expense: { id: string; category_id: string; name: string; amount_cents: number; expense_at: string } | null = null;
let categories: CategoryRow[] = [];
let notFound = false;

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (supabase && user) {
  const { data: expData } = await supabase
    .from("expenses")
    .select("id,category_id,name,amount_cents,expense_at")
    .eq("id", id)
    .single();

  if (!expData) {
    notFound = true;
  } else {
    expense = expData;
  }

  const { data: catData } = await supabase
    .from("categories")
    .select("id,name,is_system")
    .eq("year", year)
    .order("is_system", { ascending: true })
    .order("name", { ascending: true });
  categories = catData ?? [];
}

const initial = expense
  ? {
      categoryId: expense.category_id,
      amount: (expense.amount_cents / 100).toFixed(2),
      name: expense.name,
      date: new Intl.DateTimeFormat("en-CA", {
        timeZone: "Europe/Warsaw",
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
      }).format(new Date(expense.expense_at)),
    }
  : undefined;
---

<AppShell title="Edit Expense">
  <BackLink href="/report?view=monthly">← Monthly report</BackLink>

  <PageTitle title="Edit Expense" subtitle={`Budget year ${year}`} />

  {
    notFound ? (
      <EmptyState>
        Expense not found.{" "}
        <a href="/report?view=monthly" class="text-purple-300 underline">
          Back to monthly report.
        </a>
      </EmptyState>
    ) : categories.length === 0 ? (
      <EmptyState>
        No categories yet.{" "}
        <a href="/categories" class="text-purple-300 underline">
          Create a category first.
        </a>
      </EmptyState>
    ) : (
      <ExpenseForm
        client:load
        categories={categories}
        today={today}
        initial={initial}
        action={`/api/expenses/${id}`}
        submitLabel="Update expense"
        serverError={error}
      />
    )
  }
</AppShell>

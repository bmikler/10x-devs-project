---
import AppShell from "@/components/AppShell.astro";
import PageTitle from "@/components/ui/PageTitle.astro";
import Card from "@/components/ui/Card.astro";
import EmptyState from "@/components/ui/EmptyState.astro";
import CategoryForm from "@/components/categories/CategoryForm";
import CategoryList from "@/components/categories/CategoryList";
import { createClient } from "@/lib/supabase";
import { getCurrentBudgetYear } from "@/lib/budget-year";

const { user } = Astro.locals;
const error = Astro.url.searchParams.get("error");
const year = getCurrentBudgetYear();

const supabase = createClient(Astro.request.headers, Astro.cookies);

interface CategoryRow {
  id: string;
  name: string;
  type: string;
  limit_cents: number | null;
  is_system: boolean;
}

let categories: CategoryRow[] = [];
if (supabase && user) {
  // RLS scopes this to the signed-in user. Order user rows first, "other" last.
  const { data } = await supabase
    .from("categories")
    .select("id,name,type,limit_cents,is_system")
    .eq("year", year)
    .order("is_system", { ascending: true })
    .order("name", { ascending: true });
  categories = data ?? [];
}

const userCategories = categories.filter((c) => !c.is_system);
---

<AppShell title="Categories">
  <PageTitle title="Categories" subtitle={`Budget year ${year}`} />

  {
    categories.length === 0 ? (
      <EmptyState class="mb-6">No categories yet. Create your first one below to start budgeting.</EmptyState>
    ) : (
      <CategoryList categories={categories} client:load />
    )
  }

  {
    userCategories.length === 0 && categories.length > 0 && (
      <p class="mb-4 text-center text-sm text-blue-100/60">Add your first category below.</p>
    )
  }

  <Card>
    <h2 class="mb-4 text-lg font-semibold">Add a category</h2>
    <CategoryForm serverError={error} client:load />
  </Card>
</AppShell>

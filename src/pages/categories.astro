---
import AppShell from "@/components/AppShell.astro";
import PageTitle from "@/components/ui/PageTitle.astro";
import EmptyState from "@/components/ui/EmptyState.astro";
import CategoryList from "@/components/categories/CategoryList";
import { createClient } from "@/lib/supabase";
import { getCurrentBudgetYear } from "@/lib/budget-year";

const { user } = Astro.locals;
const year = getCurrentBudgetYear();

const supabase = createClient(Astro.request.headers, Astro.cookies);

interface CategoryRow {
  id: string;
  name: string;
  type: string;
  limit_cents: number | null;
  is_system: boolean;
}

let categories: CategoryRow[] = [];
if (supabase && user) {
  // RLS scopes this to the signed-in user. Order user rows first, "other" last.
  const { data } = await supabase
    .from("categories")
    .select("id,name,type,limit_cents,is_system")
    .eq("year", year)
    .order("is_system", { ascending: true })
    .order("name", { ascending: true });
  categories = data ?? [];
}
---

<AppShell title="Categories">
  <PageTitle title="Categories" subtitle={`Budget year ${year}`} />

  <a
    href="/categories/new"
    class="mb-6 flex w-full items-center justify-center gap-2 rounded-lg bg-purple-600 px-4 py-3 text-base font-medium text-white transition-colors hover:bg-purple-500 focus-visible:ring-2 focus-visible:ring-purple-400 focus-visible:outline-none"
  >
    + Add category
  </a>

  {
    categories.length === 0 ? (
      <EmptyState>No categories yet. Tap “Add category” above to create your first one.</EmptyState>
    ) : (
      <CategoryList categories={categories} client:load />
    )
  }
</AppShell>

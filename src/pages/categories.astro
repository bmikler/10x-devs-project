---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import CategoryForm from "@/components/categories/CategoryForm";
import { createClient } from "@/lib/supabase";
import { getCurrentBudgetYear } from "@/lib/budget-year";
import { formatCentsToPln } from "@/lib/money";

const { user } = Astro.locals;
const error = Astro.url.searchParams.get("error");
const year = getCurrentBudgetYear();

const supabase = createClient(Astro.request.headers, Astro.cookies);

interface CategoryRow {
  id: string;
  name: string;
  type: string;
  limit_cents: number | null;
  is_system: boolean;
}

let categories: CategoryRow[] = [];
if (supabase && user) {
  // RLS scopes this to the signed-in user. Order user rows first, "other" last.
  const { data } = await supabase
    .from("categories")
    .select("id,name,type,limit_cents,is_system")
    .eq("year", year)
    .order("is_system", { ascending: true })
    .order("name", { ascending: true });
  categories = data ?? [];
}

const userCategories = categories.filter((c) => !c.is_system);

function typeLabel(type: string) {
  return type === "recurring" ? "Monthly" : "Annual";
}
---

<Layout title="Categories">
  <div class="bg-cosmic flex min-h-screen flex-col p-4">
    <div class="mx-auto w-full max-w-md">
      <Topbar />

      <h1
        class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-3xl font-bold text-transparent"
      >
        Categories
      </h1>
      <p class="mb-6 text-center text-blue-100/80">Budget year {year}</p>

      {
        categories.length === 0 ? (
          <div class="mb-6 rounded-2xl border border-white/10 bg-white/5 p-6 text-center text-blue-100/70">
            No categories yet. Create your first one below to start budgeting.
          </div>
        ) : (
          <ul class="mb-6 flex flex-col gap-3">
            {categories.map((category) =>
              category.is_system ? (
                <li class="flex items-center gap-3 rounded-2xl border border-amber-300/30 bg-amber-400/10 p-4 text-white">
                  <span class="text-2xl">🗂️</span>
                  <div class="flex-1">
                    <div class="font-semibold text-amber-100">{category.name}</div>
                    <div class="text-xs text-amber-100/70">Catch-all · auto-managed</div>
                  </div>
                </li>
              ) : (
                <li class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/10 p-4 text-white backdrop-blur-xl">
                  <span class="text-2xl">📁</span>
                  <div class="flex-1">
                    <div class="font-semibold">{category.name}</div>
                    <div class="text-xs text-blue-100/70">{typeLabel(category.type)}</div>
                  </div>
                  {category.limit_cents !== null && (
                    <div class="text-right text-sm font-medium text-blue-100">
                      {formatCentsToPln(category.limit_cents)}
                    </div>
                  )}
                </li>
              ),
            )}
          </ul>
        )
      }

      {
        userCategories.length === 0 && categories.length > 0 && (
          <p class="mb-4 text-center text-sm text-blue-100/60">Add your first category below.</p>
        )
      }

      <div class="rounded-2xl border border-white/10 bg-white/10 p-6 text-white backdrop-blur-xl">
        <h2 class="mb-4 text-lg font-semibold">Add a category</h2>
        <CategoryForm serverError={error} client:load />
      </div>
    </div>
  </div>
</Layout>

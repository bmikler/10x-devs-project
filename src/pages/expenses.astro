---
import AppShell from "@/components/AppShell.astro";
import PageTitle from "@/components/ui/PageTitle.astro";
import EmptyState from "@/components/ui/EmptyState.astro";
import ExpenseForm from "@/components/expenses/ExpenseForm";
import { createClient } from "@/lib/supabase";
import { getCurrentBudgetYear } from "@/lib/budget-year";

const { user } = Astro.locals;
const error = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success") === "1";
const year = getCurrentBudgetYear();

/** Compute today as YYYY-MM-DD in Warsaw TZ (Workers run in UTC). */
function todayInWarsaw(): string {
  return new Intl.DateTimeFormat("en-CA", {
    timeZone: "Europe/Warsaw",
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).format(new Date());
}

const today = todayInWarsaw();

interface CategoryRow {
  id: string;
  name: string;
  is_system: boolean;
}

let categories: CategoryRow[] = [];
const supabase = createClient(Astro.request.headers, Astro.cookies);
if (supabase && user) {
  // is_system=false first (user rows), then the system "other" row last.
  const { data } = await supabase
    .from("categories")
    .select("id,name,is_system")
    .eq("year", year)
    .order("is_system", { ascending: true })
    .order("name", { ascending: true });
  categories = data ?? [];
}
---

<AppShell title="Log Expense">
  <PageTitle title="Log Expense" subtitle={`Budget year ${year}`} />

  {
    categories.length === 0 ? (
      <EmptyState>
        No categories yet.{" "}
        <a href="/categories" class="text-purple-300 underline">
          Create a category first.
        </a>
      </EmptyState>
    ) : (
      <ExpenseForm client:load categories={categories} today={today} serverError={error} success={success} />
    )
  }
</AppShell>

---
import AppShell from "@/components/AppShell.astro";
import PageTitle from "@/components/ui/PageTitle.astro";
import BackLink from "@/components/ui/BackLink.astro";
import Alert from "@/components/ui/Alert.astro";
import EmptyState from "@/components/ui/EmptyState.astro";
import MonthlyReport from "@/components/report/MonthlyReport";
import { createClient } from "@/lib/supabase";
import { getCurrentBudgetYear } from "@/lib/budget-year";
import type { ReportCategory, MonthExpense } from "@/lib/report";

const { user } = Astro.locals;
const year = getCurrentBudgetYear();
const successParam = Astro.url.searchParams.get("success");
const errorParam = Astro.url.searchParams.get("error");
const successMessage =
  successParam === "updated" ? "Expense updated" : successParam === "deleted" ? "Expense deleted" : null;

// Current month in Warsaw (1-12). The switcher lists January → this month only,
// never the future — consistent with the yearly report's future-exclusion cutoff.
const currentMonth = Number(
  new Intl.DateTimeFormat("en-US", {
    timeZone: "Europe/Warsaw",
    month: "numeric",
  }).format(new Date()),
);

const MONTH_NAMES = [
  "January",
  "February",
  "March",
  "April",
  "May",
  "June",
  "July",
  "August",
  "September",
  "October",
  "November",
  "December",
];

const months = Array.from({ length: currentMonth }, (_, i) => {
  const monthNumber = i + 1;
  return {
    key: `${year}-${String(monthNumber).padStart(2, "0")}`,
    label: MONTH_NAMES[i],
  };
});
const defaultMonth = `${year}-${String(currentMonth).padStart(2, "0")}`;

const supabase = createClient(Astro.request.headers, Astro.cookies);

let categories: ReportCategory[] = [];
let expenses: MonthExpense[] = [];

if (supabase && user) {
  const { data: catData } = await supabase
    .from("categories")
    .select("id,name,type,limit_cents,is_system")
    .eq("year", year)
    .order("is_system", { ascending: true })
    .order("name", { ascending: true });
  categories = catData ?? [];

  // Cap at the start of the next month so future-dated expenses don't surface.
  // December wraps to January of the following year.
  const expenseCutoff =
    currentMonth < 12 ? `${year}-${String(currentMonth + 1).padStart(2, "0")}-01` : `${year + 1}-01-01`;

  const { data: expData } = await supabase
    .from("expenses")
    .select("id,category_id,name,amount_cents,expense_at")
    .gte("expense_at", `${year}-01-01`)
    .lt("expense_at", expenseCutoff);
  expenses = expData ?? [];
}

const hasCategories = categories.length > 0;
---

<AppShell title="Monthly report">
  <BackLink href="/report">← Reports</BackLink>

  <PageTitle title="Monthly report" subtitle={`Budget year ${year}`} />

  {
    successMessage && (
      <Alert variant="success" class="mb-4 text-center font-medium">
        {successMessage} ✓
      </Alert>
    )
  }
  {
    errorParam && (
      <Alert variant="error" class="mb-4 text-center font-medium">
        {errorParam}
      </Alert>
    )
  }

  {
    !hasCategories ? (
      <EmptyState>
        No categories yet.{" "}
        <a href="/categories" class="text-purple-300 underline">
          Create a category first.
        </a>
      </EmptyState>
    ) : (
      <MonthlyReport
        client:load
        categories={categories}
        expenses={expenses}
        months={months}
        defaultMonth={defaultMonth}
      />
    )
  }
</AppShell>

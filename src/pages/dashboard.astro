---
import AppShell from "@/components/AppShell.astro";
import PageTitle from "@/components/ui/PageTitle.astro";

const { user } = Astro.locals;

// "Log expense" is the dominant primary action (NN/g: lead with the primary
// task), rendered as a prominent hero card above the two secondary shortcuts.
const primary = {
  href: "/expenses",
  icon: "💸",
  title: "Log expense",
  description: "Record a new expense",
};

const secondary = [
  {
    href: "/categories",
    icon: "📂",
    title: "Categories",
    description: "Manage your budget categories",
  },
  {
    href: "/report",
    icon: "📊",
    title: "Report",
    description: "View spending vs plan",
  },
];
---

<AppShell title="Dashboard">
  <PageTitle title="Budget Tracker" />
  <p class="mb-6 text-center text-blue-100/80">
    Welcome, <span class="font-semibold text-white">{user?.email}</span>
  </p>

  <a
    href={primary.href}
    class="mb-4 flex min-h-24 items-center gap-4 rounded-2xl border border-purple-400/40 bg-purple-500/20 p-6 text-white backdrop-blur-xl transition-colors hover:bg-purple-500/30 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:outline-none"
  >
    <span class="text-4xl">{primary.icon}</span>
    <div>
      <div class="text-xl font-bold">{primary.title}</div>
      <div class="text-sm text-blue-100/80">{primary.description}</div>
    </div>
  </a>

  <div class="flex flex-col gap-3">
    {
      secondary.map((action) => (
        <a
          href={action.href}
          class="flex min-h-20 items-center gap-4 rounded-2xl border border-white/10 bg-white/10 p-4 text-white backdrop-blur-xl transition-colors hover:bg-white/20 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:outline-none"
        >
          <span class="text-3xl">{action.icon}</span>
          <div>
            <div class="text-lg font-semibold">{action.title}</div>
            <div class="text-sm text-blue-100/70">{action.description}</div>
          </div>
        </a>
      ))
    }
  </div>
</AppShell>

---
import AppShell from "@/components/AppShell.astro";
import PageTitle from "@/components/ui/PageTitle.astro";
import { getCurrentBudgetYear } from "@/lib/budget-year";

const year = getCurrentBudgetYear();

const reports = [
  {
    href: "/report/monthly",
    icon: "📅",
    title: "Monthly",
    description: "One month at a time, grouped by category",
  },
  {
    href: "/report/yearly",
    icon: "📊",
    title: "Yearly",
    description: "Spending vs plan across the budget year",
  },
];
---

<AppShell title="Report">
  <PageTitle title="Report" subtitle={`Budget year ${year}`} />

  <div class="flex flex-col gap-3">
    {
      reports.map((report) => (
        <a
          href={report.href}
          class="flex min-h-20 items-center gap-4 rounded-2xl border border-white/10 bg-white/10 p-4 text-white backdrop-blur-xl transition-colors hover:bg-white/20 focus-visible:ring-2 focus-visible:ring-purple-300 focus-visible:outline-none"
        >
          <span class="text-3xl">{report.icon}</span>
          <div>
            <div class="text-lg font-semibold">{report.title}</div>
            <div class="text-sm text-blue-100/70">{report.description}</div>
          </div>
        </a>
      ))
    }
  </div>
</AppShell>

---
import AppShell from "@/components/AppShell.astro";
import { getCurrentBudgetYear } from "@/lib/budget-year";

const year = getCurrentBudgetYear();

const reports = [
  {
    href: "/report/monthly",
    icon: "📅",
    title: "Monthly",
    description: "One month at a time, grouped by category",
  },
  {
    href: "/report/yearly",
    icon: "📊",
    title: "Yearly",
    description: "Spending vs plan across the budget year",
  },
];
---

<AppShell title="Report">
  <h1
    class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-3xl font-bold text-transparent"
  >
    Report
  </h1>
  <p class="mb-6 text-center text-blue-100/80">Budget year {year}</p>

  <div class="flex flex-col gap-4">
    {
      reports.map((report) => (
        <a
          href={report.href}
          class="flex min-h-20 items-center gap-4 rounded-2xl border border-white/10 bg-white/10 p-5 text-white backdrop-blur-xl transition-colors hover:bg-white/20"
        >
          <span class="text-3xl">{report.icon}</span>
          <div>
            <div class="text-lg font-semibold">{report.title}</div>
            <div class="text-sm text-blue-100/70">{report.description}</div>
          </div>
        </a>
      ))
    }
  </div>
</AppShell>
